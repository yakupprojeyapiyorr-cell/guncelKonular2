# Environment variables for FocusFlow

# Database
DB_PASSWORD=focusflow123

# JWT Secret (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-in-production

# External APIs
YOUTUBE_API_KEY=your-youtube-api-key-here
LLM_API_KEY=your-openai-or-claude-key-here

# Redis (usually localhost for dev)
REDIS_HOST=redis
REDIS_PORT=6379

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev
